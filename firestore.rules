rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Authentication Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isBpnEmployee() {
      return isSignedIn() && 
             request.auth.token != null &&
             request.auth.token.email != null && (
               request.auth.token.email.matches('.*@bpn[.]go[.]id') || 
               request.auth.token.email == 'admin@bpn.go.id' ||
               request.auth.token.email == 'datacenter.kartawijaya@gmail.com'
             );
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.uid == 'xmuLTnzNj6ZAmsHsN4mLsXSpxiI2' || isBpnEmployee());
    }

    function isStaff() {
      return isSignedIn() && (request.auth.uid == 'xmuLTnzNj6ZAmsHsN4mLsXSpxiI2' || isBpnEmployee());
    }

    // Validation Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entities Validations for Secure DB Writing
    function isValidArchive(data) {
      return data.type in ['BUKU_TANAH', 'WARKAH', 'SURAT_UKUR'] &&
             data.namaPemegangHak is string && data.namaPemegangHak.size() > 0 &&
             data.namaPemegangHak.size() <= 255;
    }

    function isValidLoan(data) {
      return data.archiveId is string && data.archiveId.size() > 0 &&
             data.borrowerName is string && data.borrowerName.size() > 0 &&
             data.status in ['Active', 'Returned', 'Overdue'] &&
             data.loanDate is string &&
             data.expectedReturnDate is string;
    }

    function isValidNotification(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 500 &&
             data.body is string && data.body.size() > 0 && data.body.size() <= 2000 &&
             data.type is string && data.type.size() <= 100 &&
             data.category is string && data.category.size() <= 100 &&
             data.isRead is bool;
    }

    // Route rules

    // 1. Archives collection
    match /archives/{archiveId} {
      allow read: if isSignedIn();
      allow create, update: if isStaff() && isValidArchive(incoming());
      allow delete: if isAdmin();
    }

    // 2. Loans collection
    match /loans/{loanId} {
      allow read: if isSignedIn();
      allow create: if isStaff() && isValidLoan(incoming());
      allow update: if isStaff() && isValidLoan(incoming());
      allow delete: if isAdmin();
    }

    // 3. Users Profiles collection
    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isStaff());
      allow list: if isStaff();
      allow create, update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 4. Locations & master wilayah collection
    match /locations/{locationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 5. System Notifications collection
    match /notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }
  }
}
